#~ msgid "Show Only Active Jobs"
#~ msgstr "செயலிலுள்ள பணிகளை மட்டும் காட்டு"

#~ msgid "Search…"
#~ msgstr "தேடு…"

#~ msgid "Resume printing"
#~ msgstr "அச்சிடுவதை தொடர்"

#~ msgid "Pause printing"
#~ msgstr "அச்சிடுவதை இடைநிறுத்து"
