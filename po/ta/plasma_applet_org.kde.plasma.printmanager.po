#: src/plasmoid/FullRepresentation.qml:49 src/plasmoid/main.qml:50
msgid "Printers"
msgstr "அச்சுப்பொறிகள்"

#: src/plasmoid/FullRepresentation.qml:49
msgid "Printer Groups"
msgstr "அச்சுப்பொறி குழுக்கள்"

#: src/plasmoid/FullRepresentation.qml:83 src/plasmoid/main.qml:71
msgid "No printers have been configured or discovered"
msgstr "எந்த அச்சுப்பொறியும் அமைக்கப்படவோ கண்டறியப்படவோ இல்லை"

#: src/plasmoid/FullRepresentation.qml:83
msgid "No matches"
msgstr "பொருத்தங்கள் இல்லை"

#: src/plasmoid/main.qml:55
msgid "There is one print job in the queue"
msgid_plural "There are %1 print jobs in the queue"
msgstr[0] "அச்சுவரிசையில் ஓர் பணி உள்ளது"
msgstr[1] "அச்சுவரிசையில் %1 பணிகள் உள்ளன"

#: src/plasmoid/main.qml:64
msgctxt "Printing document name with printer name"
msgid "Printing %1 with %2"
msgstr "%1 %2 தனில் அச்சிடப்படுகிறது"

#: src/plasmoid/main.qml:66
msgctxt "Printing with printer name"
msgid "Printing with %1"
msgstr "%1 தனில் அச்சிடப்படுகிறது"

#: src/plasmoid/main.qml:69
msgid "Print queue is empty"
msgstr "அச்சுவரிசை காலியாக உள்ளது"

#: src/plasmoid/main.qml:78 src/plasmoid/PrinterDelegate.qml:70
msgctxt "Number of active print jobs"
msgid "%1"
msgstr "%1"

#: src/plasmoid/main.qml:108
msgid "&Configure Printers…"
msgstr "&அச்சுப்பொறிகளை அமை…"

#: src/plasmoid/PrinterDelegate.qml:51
msgid "Resume"
msgstr "தொடர்"

#: src/plasmoid/PrinterDelegate.qml:51
msgid "Pause"
msgstr "இடைநிறுத்து"

#: src/plasmoid/PrinterDelegate.qml:77
msgid "Configure Printer…"
msgstr "அச்சுப்பொறியை அமை…"

#: src/plasmoid/PrinterDelegate.qml:82
msgid "View Print Queue"
msgstr "அச்சுவரிசையைக் காட்டு"

#: src/plasmoid/PrinterDelegate.qml:157
msgctxt "@action:button"
msgid "Cancel"
msgstr "ரத்து செய்"

#: src/plasmoid/PrinterDelegate.qml:192
msgctxt "Number of additional print jobs"
msgid "%1 more job"
msgid_plural "%1 more jobs"
msgstr[0] "இன்னும் %1 பணி"
msgstr[1] "இன்னும் %1 பணிகள்"

